{
  "name": "automation-backend-v37",
  "version": "37.1.0",
  "description": "Enterprise Automation Backend — v37.1 — Flow Engine & Secured",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "prestart": "npm run build",
    "install:browser": "playwright install chromium",
    "install:browser:deps": "playwright install --with-deps chromium",
    "postinstall": "node -e \"if(process.env.SKIP_BROWSER_INSTALL){process.exit(0)}\" && (playwright install chromium || echo \"[postinstall] Skipped Chromium download (run npm run install:browser manually).\")"
  },
  "keywords": [
    "playwright",
    "automation",
    "bullmq",
    "redis",
    "flow-engine",
    "secure"
  ],
  "author": "Dev Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "bullmq": "^5.13.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jimp": "^1.6.0",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "safe-regex2": "^3.1.0",
    "ws": "^8.18.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/helmet": "^0.0.48",
    "@types/node": "^20.16.5",
    "rimraf": "^5.0.7",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4"
  }
}

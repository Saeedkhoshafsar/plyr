# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://127.0.0.1:6379

# ============================================
# DIRECTORIES
# ============================================
PROFILES_DIR=./profiles
LOGS_DIR=./logs

# ============================================
# CHROME (Optional)
# ============================================
# Leave EMPTY to use Playwright's bundled Chromium (recommended for Node-base/Linux).
# Set only to force a system-installed Chrome/Chromium, e.g. /usr/bin/google-chrome
CHROME_EXE=

# ============================================
# QUEUE SETTINGS
# ============================================
MAX_CONCURRENT=20
MAX_QUEUED_JOBS_PER_USER=3
MAX_STORED_JOBS_PER_USER=10
QUEUE_DELAY_MS=200

# ============================================
# TIMEOUTS
# ============================================
STEP_TIMEOUT_MS=300000
MAX_JOB_DURATION_MINUTES=90
BROWSER_LAUNCH_TIMEOUT_MS=30000

# ============================================
# BROWSER
# ============================================
DEFAULT_HEADLESS=false
TURBO_MODE=false

# ============================================
# GARBAGE COLLECTOR
# ============================================
PARTIAL_SAVE_INTERVAL=10
GC_CHECK_INTERVAL_MINUTES=10
GC_STALE_THRESHOLD_MINUTES=15
PARTIAL_FILE_MAX_AGE_HOURS=1
JOB_OUTPUT_MAX_AGE_MS=1800000

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
ADMIN_RATE_LIMIT_PER_MINUTE=30

# ============================================
# CORS (F5) - cross-origin access for the UI / n8n / extension
# ============================================
# Comma-separated allowed origins. Leave empty for same-origin only
# (the bundled dashboard works regardless). Use '*' to allow any origin
# (note: '*' disables credentials).
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5678,https://n8n.example.com
CORS_ALLOWED_ORIGINS=
GOD_MODE_IPS=127.0.0.1,::1

# ============================================
# AUTHENTICATION
# ============================================
API_KEYS_ENABLED=true
API_KEYS=sk_live_replace_me_key1,sk_live_replace_me_key2
ADMIN_SECRET=replace_with_a_long_random_secret

# ============================================
# USER PLANS
# ============================================
DEFAULT_USER_LEVEL=0

# ============================================
# WEBHOOKS
# ============================================
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_ALLOW_PRIVATE_IPS=false
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF_MS=1000
# [F3] Shared secret for signing outgoing webhooks (HMAC-SHA256). When set, each
# webhook carries X-Signature: sha256=<hex> and X-Webhook-Timestamp. Empty => unsigned.
WEBHOOK_SECRET=

# ============================================
# n8n / API INTEGRATION (F3)
# ============================================
# POST /run?wait=true blocks until the job finishes, up to RUN_WAIT_MAX_MS, then
# returns the full result inline (202 + pollUrl on timeout). RUN_WAIT_POLL_MS is
# how often the server polls the job while waiting.
RUN_WAIT_MAX_MS=60000
RUN_WAIT_POLL_MS=500
# Idempotency-Key (header on POST /run) -> jobId mapping TTL in seconds (default 24h).
IDEMPOTENCY_TTL_SECONDS=86400

# ============================================
# WORKFLOW STORAGE (G2)
# ============================================
# Saved workflows are versioned; how many past versions to keep per workflow.
# Oldest snapshots beyond this are pruned on each update. 0 = keep all.
WORKFLOW_MAX_VERSIONS=20

# ============================================
# SECURITY
# ============================================
MAX_TOTAL_EXECUTION_OPS=5000
MAX_REQUEST_BODY_SIZE=20mb
MAX_REGEX_LENGTH=100
USE_LUA_QUOTA=true
MAX_VARIABLE_SIZE_KB=100

# ============================================
# HYBRID ARCHITECTURE (VIP vs Free)
# ============================================
VIP_PRIORITY_THRESHOLD=100
FREE_CONTEXT_MAX_LIFETIME_MS=600000
FREE_RESOURCE_BLOCKING=true
FREE_FORCE_SEQUENTIAL=true

# ============================================
# FLATTENER (Free Users Tab Control)
# ============================================
FREE_FLATTENER_ENABLED=true
FLATTENER_URL_CAPTURE_TIMEOUT_MS=2000
FLATTENER_REDIRECT_TO_MAIN=true

# ============================================
# CANCEL SETTINGS
# ============================================
TAB_CLOSE_TIMEOUT_MS=5000


USER_PLANS={"0":{"quota":5,"maxTabs":1,"maxSteps":5,"priority":100},"1":{"quota":15,"maxTabs":3,"maxSteps":20,"priority":50},"2":{"quota":60,"maxTabs":10,"maxSteps":100,"priority":10}}

# Schedule Limits
MAX_SCHEDULES_FREE=2
MAX_SCHEDULES_VIP=10
MAX_REPEAT_LIMIT_FREE=100
